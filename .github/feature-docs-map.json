  "changeDetectionRules": {
    "major": {
      "patterns": [
        "breaking change",
        "BREAKING CHANGE:",
        "removed feature",
        "deprecated",
        "migration required"
      ],
      "fileChanges": [
        "route removed",
        "API endpoint removed",
        "component deleted"
      ]
    },
    "minor": {
      "patterns": [
        "feat:",
        "feature:",
        "add:",
        "new feature"
      ],
      "fileChanges": [
        "new route",
        "new API endpoint",
        "new component"
      ]
    },
    "patch": {
      "patterns": [
        "fix:",
        "bugfix:",
        "patch:"
      ]
    },
    "ui-change": {
      "patterns": [
        "ui:",
        "style:",
        "design:"
      ],
      "filePatterns": [
        "*.tsx",
        "*.jsx",
        "*.css",
        "components/**"
      ]
    }
  },
  "screenshotConfig": {
    "baseUrl": "http://localhost:3000",
    "viewportWidth": 1920,
    "viewportHeight": 1080,
    "deviceScaleFactor": 1,
    "timeout": 30000,
    "waitForSelectors": true,
    "captureFullPage": false
  },
  "documentationTemplates": {
    "featureAdded": "## New Feature: {featureName}\n\n{description}\n\n### How to Use\n\n1. {step1}\n2. {step2}\n3. {step3}\n\n![{featureName}](../screenshots/{screenshot})\n*Figure: {caption}*\n\n### Availability\n\n- **Community**: {communityAvailability}\n- **Pro**: {proAvailability}\n- **Enterprise**: {enterpriseAvailability}\n- **Gov Cloud**: {govcloudAvailability}\n",
    "featureChanged": "## Updated: {featureName}\n\n**What Changed**: {changeDescription}\n\n**Impact**: {impact}\n\n### Migration Guide\n\n{migrationSteps}\n\n![Updated {featureName}](../screenshots/{screenshot})\n*Figure: {caption}*\n",
    "featureRemoved": "## ⚠️ Removed: {featureName}\n\n**Reason**: {reason}\n\n**Alternative**: {alternative}\n\n### Migration Guide\n\n{migrationSteps}\n\n**Removed in version**: {version}\n"
  },
  "reviewers": {
    "default": ["@docs-team"],
    "byFeature": {
      "ai-copilot": ["@docs-team", "@ai-team"],
      "ai-analysis": ["@docs-team", "@ai-team"],
      "security": ["@docs-team", "@security-team"],
      "integrations": ["@docs-team", "@integrations-team"]
    }
  }
