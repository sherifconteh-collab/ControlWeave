{
  "servers": {
    "controlweave": {
      "type": "stdio",
      "command": "node",
      "args": [
        "${workspaceFolder}/controlweave/backend/scripts/mcp-server-secure.js"
      ],
      "env": {
        "GRC_API_BASE_URL": "http://localhost:3001/api/v1",
        "NODE_ENV": "development",
        "MCP_ENABLE_AUDIT_LOG": "true",
        "MCP_CLIENT_NAME": "VS Code + GitHub Copilot",
        "MCP_CLIENT_VERSION": "1.0.0"
      }
    }
  }
}
