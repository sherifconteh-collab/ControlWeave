# ControlWeave Community Edition
# Open source · Free tier · Self-hostable
#
# ─────────────────────────────────────────────────────────────────────────────
# Database Configuration
# Option A (recommended for hosted Postgres): single URL
DATABASE_URL=

# Option B (local/dev): discrete fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grc_platform
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# Database SSL (set DB_SSL_MODE=require for managed providers that require TLS)
DB_SSL_MODE=disable
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECT_TIMEOUT_MS=2000

# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# JWT Configuration
JWT_SECRET=change-this-to-a-long-random-string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Account lockout (optional — defaults shown)
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# Optional platform-level AI provider keys (BYOK can override per org)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
XAI_API_KEY=
XAI_API_BASE=https://api.x.ai/v1

# Groq (free-tier, OpenAI-compatible — get a free key at console.groq.com)
GROQ_API_KEY=

# Ollama (self-hosted local LLM — no API key needed, OpenAI-compatible)
# Run: ollama serve  |  then pull a model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# AI usage policy
# false = org BYOK traffic does not consume platform tier limits (default)
# true  = enforce tier AI limits even when org uses its own key
AI_LIMIT_APPLIES_TO_BYOK=false

# Reminder scheduler
ENABLE_REMINDERS=true
REMINDER_INTERVAL_MINUTES=60

# Evidence defaults
EVIDENCE_DEFAULT_RETENTION_DAYS=365

# Migration runner behavior
# true = if an old migration was already applied manually, baseline and continue
MIGRATION_BASELINE_ON_ERROR=true

# Database backup job (used by: npm run db:backup)
DB_BACKUP_DIR=./backups
DB_BACKUP_RETENTION_DAYS=7
# custom = pg_dump custom format (.dump), plain = .sql
DB_BACKUP_FORMAT=custom
# Optional: explicit binary path if pg_dump is not on PATH
PG_DUMP_PATH=

# Capacity/upgrade thresholds (used by: npm run db:capacity)
DB_UPGRADE_THRESHOLD_GB=3
DB_UPGRADE_THRESHOLD_CONNECTION_UTILIZATION_PCT=70
DB_UPGRADE_THRESHOLD_AUDIT_LOG_ROWS=250000
DB_UPGRADE_THRESHOLD_EVIDENCE_ROWS=50000
DB_UPGRADE_THRESHOLD_ASSESSMENT_RESULTS_ROWS=50000

# Splunk connector behavior
SPLUNK_REQUEST_TIMEOUT_MS=30000
SPLUNK_SEARCH_MAX_WAIT_MS=30000

# MCP server runtime (only used by `npm run mcp`)
GRC_API_BASE_URL=http://localhost:3001/api/v1
GRC_API_TOKEN=
GRC_HEALTH_URL=http://localhost:3001/health
