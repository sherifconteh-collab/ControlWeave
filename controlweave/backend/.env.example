# Database Configuration
# Option A (recommended for hosted Postgres): single URL
DATABASE_URL=

# Option B (local/dev): discrete fields
DB_HOST=localhost
DB_PORT=5432
DB_NAME=grc_platform
DB_USER=postgres
DB_PASSWORD=your_database_password_here

# Database SSL (set DB_SSL_MODE=require for managed providers that require TLS)
DB_SSL_MODE=disable
DB_SSL_REJECT_UNAUTHORIZED=true
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT_MS=30000
DB_POOL_CONNECT_TIMEOUT_MS=2000

# Edition Configuration
# Controls which features are available at the API level
# - "community": Open source edition with core compliance features only.
#                Set this for self-hosted community deployments.
# - "pro": Professional/Enterprise edition with all features (CMDB, SBOM, Threat Intel, etc.)
# Default: pro (this repo is the Pro edition)
# Self-hosted community users should set: EDITION=community
EDITION=pro

# Server Configuration
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
FRONTEND_URL=http://localhost:3000

# JWT Configuration
# Generate with: npm run security:generate-jwt-secret
JWT_SECRET=replace-with-at-least-32-char-random-secret

# BYOK API key encryption — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Required in production; development uses a safe fallback automatically.
ENCRYPTION_KEY=
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_DEMO_SESSION_EXPIRY=8h

# WebAuthn / Passkeys (required for passkey sign-in)
# WEBAUTHN_RP_NAME is the display name shown in the passkey dialog
# WEBAUTHN_RP_ID must match the hostname users access the app on (no port, no protocol)
# WEBAUTHN_ORIGIN must be the full origin (protocol + host + optional port)
WEBAUTHN_RP_NAME=ControlWeave
WEBAUTHN_RP_ID=localhost
WEBAUTHN_ORIGIN=http://localhost:3000

# Social OAuth providers (optional — enables social sign-in buttons on the login page)
# Obtain credentials from each provider's developer console.
# Redirect URIs must be set to: <BACKEND_URL>/api/v1/sso/callback/<provider>
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Backend public URL (used for OAuth redirect URIs)
BACKEND_URL=http://localhost:3001

# Account lockout (optional — defaults shown)
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_DURATION_MS=900000

# Optional platform-level AI provider keys (BYOK can override per org)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
XAI_API_KEY=
XAI_API_BASE=https://api.x.ai/v1

# Groq (free-tier, OpenAI-compatible — get a free key at console.groq.com)
GROQ_API_KEY=

# Ollama (self-hosted local LLM — no API key needed, OpenAI-compatible)
# Run: ollama serve  |  then pull a model: ollama pull llama3.2
OLLAMA_BASE_URL=http://localhost:11434/v1

# AI usage policy
# false = org BYOK traffic does not consume platform tier limits (default)
# true  = enforce tier AI limits even when org uses its own key
AI_LIMIT_APPLIES_TO_BYOK=false

# AI reliability: retry & fallback configuration
# Number of retries for transient errors (429 rate limits, 5xx server errors) before failing or using fallback
AI_MAX_RETRIES=2
# Base delay in ms between retries (doubles each attempt: 1000ms → 2000ms → 4000ms)
AI_RETRY_BASE_DELAY_MS=1000
# Optional fallback provider if the primary fails after all retries (claude|openai|gemini|grok|groq|ollama)
AI_FALLBACK_PROVIDER=
# Maximum assets evaluated per IAVM asset-alert AI call (default: 500)
AI_IAVM_MAX_ASSETS=500
# PII/PHI enforcement: by default PHI detected in LLM input is blocked (HTTP 422, HIPAA §164.514 safe-harbour).
# Set to "true" ONLY when routing exclusively to HIPAA-BAA-covered providers (e.g. AWS Bedrock with a signed BAA).
# PII is always redacted inline regardless of this setting.
PHI_REDACT_ONLY=

# Email / SMTP (optional — enables email notifications)
# Leave SMTP_HOST blank to disable email delivery; in-app notifications still work.
# Example providers: smtp.sendgrid.net (587), smtp.gmail.com (587), email-smtp.us-east-1.amazonaws.com (587)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=noreply@yourdomain.com
FROM_NAME=ControlWeave

# Reminder scheduler
ENABLE_REMINDERS=true
REMINDER_INTERVAL_MINUTES=60

# Real-time features (WebSocket + Redis)
# Redis is optional for single-instance deployments.
# Set REDIS_REQUIRED=true in production to fail fast if Redis is missing/unavailable.
REDIS_REQUIRED=false
REDIS_URL=
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Evidence defaults
EVIDENCE_DEFAULT_RETENTION_DAYS=365

# Migration runner behavior
# true = if an old migration was already applied manually, baseline and continue
MIGRATION_BASELINE_ON_ERROR=true

# Database backup job (used by: npm run db:backup)
DB_BACKUP_DIR=./backups
DB_BACKUP_RETENTION_DAYS=7
# custom = pg_dump custom format (.dump), plain = .sql
DB_BACKUP_FORMAT=custom
# Optional: explicit binary path if pg_dump is not on PATH
PG_DUMP_PATH=

# Scheduled backup (set BACKUP_ENABLED=true to activate)
BACKUP_ENABLED=false
BACKUP_CRON_SCHEDULE=0 2 * * *
# Optional S3 upload destination (if unset, backups stay local only)
AWS_S3_BUCKET=
AWS_S3_PREFIX=backups/
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Session management
MAX_CONCURRENT_SESSIONS=10
REFRESH_TOKEN_TTL_DAYS=30

# Error tracking (Sentry — optional, app works without it)
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# TPRM optional HMAC secret (adds request signing on top of access tokens)
TPRM_HMAC_SECRET=

# Rate limiting Redis key namespace
REDIS_RATE_LIMIT_PREFIX=ratelimit

# Capacity/upgrade thresholds (used by: npm run db:capacity)
DB_UPGRADE_THRESHOLD_GB=3
DB_UPGRADE_THRESHOLD_CONNECTION_UTILIZATION_PCT=70
DB_UPGRADE_THRESHOLD_AUDIT_LOG_ROWS=250000
DB_UPGRADE_THRESHOLD_EVIDENCE_ROWS=50000
DB_UPGRADE_THRESHOLD_ASSESSMENT_RESULTS_ROWS=50000

# Splunk connector behavior
SPLUNK_REQUEST_TIMEOUT_MS=30000
SPLUNK_SEARCH_MAX_WAIT_MS=30000

# Stripe (payment processing)
# Get keys from https://dashboard.stripe.com/apikeys
# Use sk_test_... / pk_test_... for development
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
# Get webhook secret from https://dashboard.stripe.com/webhooks or `stripe listen` CLI
STRIPE_WEBHOOK_SECRET=

# MCP server runtime (only used by `npm run mcp` or `npm run mcp:secure`)
GRC_API_BASE_URL=http://localhost:3001/api/v1
GRC_API_TOKEN=
GRC_HEALTH_URL=http://localhost:3001/health

# MCP Security Configuration (used by `npm run mcp:secure`)
# Rate limiting: requests per minute per tool
MCP_RATE_LIMIT=30
# Request timeout in milliseconds
MCP_REQUEST_TIMEOUT_MS=30000
# Enable comprehensive audit logging
MCP_ENABLE_AUDIT_LOG=true
# Maximum input length for text fields (characters)
MCP_MAX_INPUT_LENGTH=10000
# Maximum results returned per query
MCP_MAX_RESULT_LIMIT=200
# Client identification (optional, for enhanced audit trails)
MCP_CLIENT_NAME=
MCP_CLIENT_VERSION=

# ============================================================================
# CE-MCP (Code Execution MCP) Security Configuration
# Implements MAESTRO framework security controls for code execution
# ============================================================================

# CE-MCP Feature Toggle
CEMCP_ENABLED=false

# Static Validation
CEMCP_STATIC_VALIDATION_ENABLED=true
CEMCP_MAX_CODE_SIZE=10240
CEMCP_MAX_NESTING_DEPTH=4
CEMCP_MAX_FUNCTION_CALLS=50
CEMCP_MAX_LINES=500

# Semantic Gating
CEMCP_SEMANTIC_GATING_ENABLED=true
CEMCP_INTENT_SIMILARITY_THRESHOLD=0.7

# Sandbox Configuration
CEMCP_SANDBOX_TYPE=docker
CEMCP_CONTAINER_IMAGE=controlweave/ce-mcp-sandbox:latest
CEMCP_CPU_LIMIT=0.5
CEMCP_MEMORY_LIMIT=256m
CEMCP_DISK_LIMIT=100m
CEMCP_TIME_LIMIT=30
CEMCP_NETWORK_ENABLED=false

# Security Restrictions
CEMCP_ALLOW_SUBPROCESS=false
CEMCP_ALLOW_NETWORK=false
CEMCP_ALLOW_FILE_WRITE=true
CEMCP_WRITABLE_PATHS=/tmp

# Audit Logging
CEMCP_AUDIT_LOG_ENABLED=true
CEMCP_AUDIT_LOG_PATH=/var/log/controlweave/ce-mcp-audit.log
CEMCP_LOG_TO_CONSOLE=true
CEMCP_LOG_TO_FILE=false

# Rate Limiting (stricter than tool calls)
CEMCP_RATE_LIMIT_PER_HOUR=10
CEMCP_RATE_LIMIT_PER_DAY=50

# Exception Handling
CEMCP_REMOVE_STACK_TRACES=true
CEMCP_REDACT_PATHS=true
CEMCP_REDACT_CREDENTIALS=true
CEMCP_MAX_MESSAGE_LENGTH=500
CEMCP_VERBOSE_ERRORS=false

# Hugging Face demo data seeding (used by `npm run seed:demo:hf`)
# Comma-separated list of HF datasets to pull vulnerability data from
HF_DEMO_DATASETS=navin-hariharan/cve-dataset,zefang-liu/cve-and-cwe-mapping-dataset,JavIndra/attack-cves-data
HF_DEMO_CONFIG=default
HF_DEMO_SPLIT=train
HF_DEMO_ROWS_OFFSET=0
HF_DEMO_ROWS_LENGTH=100
HF_DEMO_TIMEOUT_MS=30000

# ── Perpetual License (for offline / self-hosted deployments) ──
# License keys are RS256/ES256-signed JWTs issued by ControlWeave sales.
# Community edition users can receive a free community license key to identify their installation.
#
# Activate once via the in-app Settings → License page — the key is saved to
# the database automatically. No .env editing required for normal use.
#
# Alternatively, set it here to pre-seed on first startup:
# CONTROLWEAVE_LICENSE_PUBKEY=<RS256-or-ES256-public-key-PEM>
# LICENSE_KEY=<jwt-license-key-from-sales>
#
# Optional: online revocation heartbeat (NEVER mandatory — offline works without it).
# If set, the server sends a background ping to this URL on startup to check
# for license revocation. Connectivity failures are logged but NEVER revoke access.
# Community tier: leave unset (fully offline, no phone-home).
# Paid tier operators: set to your ControlWeave license server URL if desired.
# LICENSE_HEARTBEAT_URL=https://license.controlweave.com/api/v1/heartbeat

# Optional: update check settings (GET /api/v1/license/update-check)
# GitHub repository to check for new releases. Defaults to the public release repo.
# UPDATE_CHECK_REPO=sherifconteh-collab/ai-grc-platform
# How many hours to cache the GitHub release response (default: 6, minimum: 1).
# UPDATE_CHECK_INTERVAL_HOURS=6
