{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "buildCommand": "cd controlweave/marketing && npm install"
  },
  "deploy": {
    "startCommand": "cd controlweave/marketing && npm start",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
