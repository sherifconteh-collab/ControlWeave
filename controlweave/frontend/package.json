{
  "name": "controlweave-frontend",
  "version": "4.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "node -e \"const fs=require('fs');if(fs.existsSync('server.js')){require('./server.js')}else{const c=require('child_process');const cmd=process.platform==='win32'?'npx.cmd':'npx';const p=c.spawn(cmd,['next','start'],{stdio:'inherit'});p.on('exit',code=>process.exit(code??1));}\"",
    "lint": "eslint .",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "generate:api-types": "openapi-typescript ../docs/openapi.yaml -o src/lib/generated/api-types.ts",
    "postinstall": "node scripts/postinstall-ajv-compat.js && node scripts/patch-eslint-ajv.js"
  },
  "dependencies": {
    "@sentry/nextjs": "^8.55.0",
    "@simplewebauthn/browser": "^13.3.0",
    "axios": "^1.15.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.475.0",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^2.15.0",
    "socket.io-client": "^4.8.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^10.4.0",
    "eslint-config-next": "^16.1.6",
    "openapi-typescript": "^7.10.1",
    "tailwindcss": "^4.0.0",
    "typescript": "5.9.3"
  },
  "overrides": {
    "minimatch": "^10.2.3",
    "socket.io-parser": "4.2.6",
    "postcss": "^8.5.10",
    "rollup": "^4.9.0",
    "uuid": "^11.1.1"
  }
}
